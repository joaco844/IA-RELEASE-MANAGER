# ── Application ────────────────────────────────────────────────────────────
APP_NAME="AI Release Manager"
ENVIRONMENT=local            # local | test | production
LOG_LEVEL=INFO

# ── Database (docker-compose overrides this for containers) ───────────────
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/release_manager

# ── Auth / crypto ──────────────────────────────────────────────────────────
# Use a long random string (>= 32 bytes)
JWT_SECRET_KEY=replace-with-a-long-random-secret-of-32+-bytes
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# Fernet key for encrypting GitLab/Slack tokens at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── AI provider (switchable: openai | gemini) ──────────────────────────────
AI_PROVIDER=openai
AI_TEMPERATURE=0.2
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# ── RAG ────────────────────────────────────────────────────────────────────
RAG_ENABLED=true
RAG_PERSIST_DIR=./data/chroma
RAG_TOP_K=6

# ── Workflow ───────────────────────────────────────────────────────────────
QA_MAX_REVISIONS=2
NODE_MAX_RETRIES=3
HOURS_SAVED_PER_RELEASE=3.0

# ── Rate limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_GENERATE=20/hour

# ── CORS (JSON list) ───────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
